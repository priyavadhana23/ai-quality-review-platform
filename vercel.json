{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/auth/login",
      "destination": "https://ai-quality-review-platform-production-2424.up.railway.app/auth/login"
    },
    {
      "source": "/auth/refresh",
      "destination": "https://ai-quality-review-platform-production-2424.up.railway.app/auth/refresh"
    },
    {
      "source": "/auth/logout",
      "destination": "https://ai-quality-review-platform-production-2424.up.railway.app/auth/logout"
    },
    {
      "source": "/users/:path*",
      "destination": "https://ai-quality-review-platform-production-2424.up.railway.app/users/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://ai-quality-review-platform-production-2424.up.railway.app/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://ai-quality-review-platform-production-2424.up.railway.app/health"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
