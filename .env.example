# ============================================================
# PR-Agent — Railway Environment Variables
# ============================================================
# Copy this to understand what to paste into the Railway
# "Variables" panel.  NEVER commit real values.
#
# Dynaconf rule: double-underscore (__) is the nested-key
# separator when envvar_prefix=False (which PR-Agent uses).
#   GITHUB__APP_ID  →  settings.github.app_id
#   GITHUB__PRIVATE_KEY  →  settings.github.private_key
# ============================================================


# ── GitHub App credentials ────────────────────────────────────
# Created at: https://github.com/settings/apps/new
# (see DEPLOY.md Step 1 for the exact settings to use)

GITHUB__APP_ID=123456
# The full RSA private key downloaded from the GitHub App page.
# Paste the entire PEM block as one env var — newlines replaced with \n
# Example:  -----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
GITHUB__PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----

# Random secret you type yourself during App creation — used to verify
# that webhooks come from GitHub, not from random internet traffic.
# Generate with:  openssl rand -hex 32
GITHUB__WEBHOOK_SECRET=your_random_webhook_secret_here

# Must be "app" for a GitHub App deployment
GITHUB__DEPLOYMENT_TYPE=app


# ── Google Gemini (Google AI Studio) ─────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_AI_STUDIO__GEMINI_API_KEY=AIza...


# ── Model selection ───────────────────────────────────────────
# These override the values in configuration.toml at runtime.
# Use models confirmed to work on your key (see DEPLOY.md Step 0).
CONFIG__MODEL=gemini/gemini-3.5-flash
CONFIG__FALLBACK_MODELS=["gemini/gemini-3.1-flash-lite"]


# ── Server tuning (optional) ──────────────────────────────────
# Railway free tier has 512 MB RAM — 2 workers is the safe ceiling.
GUNICORN_WORKERS=2

# Default is INFO. Set to DEBUG only while troubleshooting.
CONFIG__LOG_LEVEL=INFO


# ── QRP API server (FastAPI) ──────────────────────────────────
# These control the FastAPI application (not the PR-Agent engine).

# Set to "production" to activate stricter security checks at startup.
APP_ENV=production

# Comma-separated list of allowed CORS origins.
# In production, set this to your frontend domain — NEVER leave as "*".
APP_CORS_ORIGINS=https://your-frontend-domain.example.com

# Set to "true" to abort startup if APP_CORS_ORIGINS is "*" in production.
APP_CORS_STRICT=true

# JWT signing secret — generate with: openssl rand -hex 64
APP_JWT_SECRET_KEY=change-me-in-production-use-a-long-random-secret

# GitHub OAuth App credentials (separate from the GitHub App above).
APP_GITHUB_CLIENT_ID=your_oauth_client_id
APP_GITHUB_CLIENT_SECRET=your_oauth_client_secret
APP_GITHUB_CALLBACK_URL=https://api.your-domain.example.com/auth/callback

# PostgreSQL connection string — set automatically on Render via fromDatabase.
APP_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/qrp

# Redis connection string — required for caching and Celery.
# On Render/Railway: paste your managed Redis URL here.
APP_REDIS_URL=redis://user:pass@host:6379/0
