{
  "title": "AI Quality Review Platform — Overview",
  "uid": "qrp-overview",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Request Rate (req/min)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "round(rate(http_requests_total[1m]) * 60)",
        "legendFormat": "req/min"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 500 }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate (%)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "round(rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m]) * 100, 0.01)",
        "legendFormat": "error %"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "P95 Latency (s)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
        "legendFormat": "p95"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "unit": "s",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Connections",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "http_requests_inprogress",
        "legendFormat": "in-flight"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Requests per Minute",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "rate(http_requests_total[1m]) * 60",
        "legendFormat": "{{handler}} {{method}}"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 },
          "unit": "reqpm"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Response Latency Percentiles",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP Status Code Rates",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~\"2..\"}[5m])",
          "legendFormat": "2xx success"
        },
        {
          "expr": "rate(http_requests_total{status=~\"4..\"}[5m])",
          "legendFormat": "4xx client error"
        },
        {
          "expr": "rate(http_requests_total{status=~\"5..\"}[5m])",
          "legendFormat": "5xx server error"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Top 10 Endpoints by Request Rate",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "topk(10, rate(http_requests_total[5m]))",
        "legendFormat": "{{handler}} [{{method}}]"
      }]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Total Requests (1 h)",
      "gridPos": { "x": 0, "y": 20, "w": 6, "h": 4 },
      "targets": [{
        "expr": "increase(http_requests_total[1h])",
        "legendFormat": "requests"
      }],
      "options": { "reduceOptions": { "calcs": ["sum"] } }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Total Errors (1 h)",
      "gridPos": { "x": 6, "y": 20, "w": 6, "h": 4 },
      "targets": [{
        "expr": "increase(http_requests_total{status=~\"5..\"}[1h])",
        "legendFormat": "errors"
      }],
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 10 }
          ]
        }
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "P50 Latency (s)",
      "gridPos": { "x": 12, "y": 20, "w": 6, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))",
        "legendFormat": "p50"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "unit": "s"
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "x": 18, "y": 20, "w": 6, "h": 4 },
      "targets": [{
        "expr": "up{job=\"qrp-backend\"}",
        "legendFormat": "backend"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "mappings": [
          { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
        ]
      }
    }
  ]
}
